# URL of the Vite dev server or hosted web build (required on real devices; localhost is the device itself).
# Example: http://192.168.1.10:3000
EXPO_PUBLIC_GAME_URL=http://localhost:3000

# Set to 1 to load EXPO_PUBLIC_GAME_URL even in release builds (skip embedded browser dist).
# EXPO_PUBLIC_FORCE_REMOTE_URL=0
